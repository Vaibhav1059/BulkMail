# SMTP Configuration (Optional Override for Security)
# Copy this file to .env and replace the values. Do not commit .env to version control.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_SECURE=false
SMTP_SENDER_EMAIL=your_email@gmail.com
SMTP_SENDER_NAME=Your Name
SMTP_EMAILS_PER_HOUR=5000
SMTP_EMAILS_PER_DAY=50000
SMTP_DELAY_SECONDS=0.5
SMTP_TIMEOUT=10
SMTP_RETRY_ATTEMPTS=3
